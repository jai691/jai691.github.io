<script>\
/* ============== GLYPH RAIN ============== */\
(function() \{\
  const cvs = document.querySelector('canvas.rain');\
  if (!cvs) return;\
  const ctx = cvs.getContext('2d');\
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;\
\
  function resize() \{\
    cvs.width = cvs.offsetWidth;\
    cvs.height = cvs.offsetHeight;\
  \}\
  resize();\
  addEventListener('resize', resize);\
\
  const COL_W = 20;\
  let COLS = Math.floor(cvs.width / COL_W);\
  let drops = Array.from(\{ length: COLS \}, () => Math.random() * -cvs.height);\
  const CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\{\}[]()<>/\\\\|=+-*&^%$#@!';\
  const ripples = [];\
\
  // re-init drops on resize\
  addEventListener('resize', () => \{\
    COLS = Math.floor(cvs.width / COL_W);\
    drops = Array.from(\{ length: COLS \}, () => Math.random() * -cvs.height);\
  \});\
\
  // pause when hero is off-screen\
  let active = true;\
  const heroObs = new IntersectionObserver(([e]) => \{ active = e.isIntersecting; \});\
  heroObs.observe(document.querySelector('.hero'));\
\
  cvs.addEventListener('click', (e) => \{\
    const rect = cvs.getBoundingClientRect();\
    const x = e.clientX - rect.left;\
    const y = e.clientY - rect.top;\
    ripples.push(\{ x, y, r: 0, life: 0 \});\
  \});\
\
  function frame() \{\
    if (!active || prefersReduced) \{ requestAnimationFrame(frame); return; \}\
    ctx.fillStyle = 'rgba(10,10,10,0.08)';\
    ctx.fillRect(0, 0, cvs.width, cvs.height);\
    ctx.font = '14px "JetBrains Mono", monospace';\
\
    drops.forEach((y, i) => \{\
      const x = i * COL_W;\
      const bright = Math.random() < 0.02;\
      ctx.fillStyle = bright ? 'rgba(255,235,200,0.95)' : 'rgba(200,170,130,0.65)';\
      ctx.fillText(CHARS[Math.floor(Math.random() * CHARS.length)], x, y);\
      drops[i] = y > cvs.height && Math.random() > 0.975 ? 0 : y + 12;\
    \});\
\
    ripples.forEach(p => \{\
      p.r += 1.2;\
      p.life += 0.01;\
      ctx.strokeStyle = `rgba(200,170,130,$\{0.4 * (1 - p.life)\})`;\
      ctx.lineWidth = 1;\
      ctx.beginPath();\
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);\
      ctx.stroke();\
    \});\
    for (let i = ripples.length - 1; i >= 0; i--) \{\
      if (ripples[i].life > 1) ripples.splice(i, 1);\
    \}\
    requestAnimationFrame(frame);\
  \}\
  frame();\
\})();\
\
/* ============== SCRAMBLE DECODE ============== */\
(function() \{\
  const TARGET = 'JANMEJAY_DIXIT';\
  const CHARS = '!<>-_\\\\/[]\{\}\'97=+*^?#________01';\
  const el = document.getElementById('hero-title');\
  if (!el) return;\
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;\
\
  if (prefersReduced) \{ el.textContent = TARGET; return; \}\
\
  let iter = 0;\
  const max = TARGET.length * 8;\
  el.classList.add('is-decoding');\
\
  function tick() \{\
    el.textContent = TARGET.split('').map((ch, i) => \{\
      if (ch === '_' || ch === ' ') return ch;\
      return i < iter / 8 ? TARGET[i] : CHARS[Math.floor(Math.random() * CHARS.length)];\
    \}).join('');\
    iter += 1;\
    if (iter >= max) \{\
      el.textContent = TARGET;\
      el.classList.remove('is-decoding');\
      return;\
    \}\
    setTimeout(tick, 45);\
  \}\
\
  // start after hero eyebrow appears\
  setTimeout(tick, 600);\
\})();\
\
/* ============== CUSTOM CURSOR ============== */\
(function() \{\
  const dot = document.getElementById('cursor-dot');\
  if (!dot) return;\
  if ('ontouchstart' in window || matchMedia('(pointer: coarse)').matches) \{\
    dot.style.display = 'none';\
    return;\
  \}\
\
  const pos = \{ x: -100, y: -100 \};\
  const target = \{ x: -100, y: -100 \};\
  let hover = false;\
\
  addEventListener('mousemove', e => \{\
    target.x = e.clientX;\
    target.y = e.clientY;\
  \});\
\
  document.addEventListener('mouseover', e => \{\
    if (e.target.closest('a, button, [data-cursor-hover], .chip, .tool-card, .project-row, .principle, .tl-item')) \{\
      hover = true;\
    \}\
  \});\
  document.addEventListener('mouseout', e => \{\
    if (e.target.closest('a, button, [data-cursor-hover], .chip, .tool-card, .project-row, .principle, .tl-item')) \{\
      hover = false;\
    \}\
  \});\
\
  function loop() \{\
    pos.x += (target.x - pos.x) * 0.18;\
    pos.y += (target.y - pos.y) * 0.18;\
    const s = hover ? 40 : 6;\
    dot.style.transform = `translate($\{pos.x - s/2\}px, $\{pos.y - s/2\}px)`;\
    dot.style.width = s + 'px';\
    dot.style.height = s + 'px';\
    dot.style.background = hover ? 'transparent' : 'rgba(200,170,130,1)';\
    dot.style.borderWidth = (hover ? 1.5 : 0) + 'px';\
    dot.style.borderColor = hover ? 'rgba(200,170,130,0.7)' : 'transparent';\
    dot.style.mixBlendMode = hover ? 'normal' : 'difference';\
    requestAnimationFrame(loop);\
  \}\
  loop();\
\})();\
\
/* ============== FADE-UP OBSERVER ============== */\
(function() \{\
  const els = document.querySelectorAll('.fade-up, .fade-up-stagger');\
  const obs = new IntersectionObserver((entries) => \{\
    entries.forEach(e => \{\
      if (e.isIntersecting) \{\
        e.target.classList.add('is-in');\
        obs.unobserve(e.target);\
      \}\
    \});\
  \}, \{ threshold: 0.15, rootMargin: '0px 0px -60px 0px' \});\
\
  els.forEach(el => obs.observe(el));\
\})();\
\
/* ============== SMOOTH SCROLL FOR NAV ============== */\
(function() \{\
  document.querySelectorAll('nav a[href^="#"]').forEach(a => \{\
    a.addEventListener('click', e => \{\
      const id = a.getAttribute('href');\
      const target = document.querySelector(id);\
      if (target) \{\
        e.preventDefault();\
        target.scrollIntoView(\{ behavior: 'smooth', block: 'start' \});\
      \}\
    \});\
  \});\
\})();\
</script>\
